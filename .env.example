# Supabase Configuration
# Get these values from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextGen API Configuration
# Read-only API for PO validation and lookup
NEXTGEN_BASE_URL=https://nextgen.madison88.com
NEXTGEN_USERNAME=your-nextgen-username
NEXTGEN_PASSWORD=your-nextgen-password

# NextGen Integration
# Set to false to disable all NextGen API calls (faster, uses only buy file + product sheet data)
NEXTGEN_ENABLED=true

# NextGen Search Configuration
# Entity types to search across (default: 0,5,6,138,80,121,9,222,163,69,23,41,139,42)
NEXTGEN_SEARCH_ENTITY_TYPES=0,5,6,138,80,121,9,222,163,69,23,41,139,42
# Strip this prefix from buy file styles before searching NextGen (e.g., NF0)
NEXTGEN_STYLE_PREFIX_STRIP=NF0
# Delay between NextGen search requests in ms (default: 500)
NEXTGEN_SEARCH_DELAY_MS=500

# Google Gemini API Configuration
# Used for OCR on image/PDF files and fallback for large Excel buy file extraction
GEMINI_API_KEY=your-gemini-api-key

# Groq API Configuration
# Primary AI for Excel buy file extraction
GROQ_API_KEY=your-groq-api-key

# Ollama AI Configuration
# Primary local/remote LLM for Excel header detection and column mapping
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_TIMEOUT=300

# Optional split deployment: Netlify UI -> VPS processing API
NEXT_PUBLIC_PROCESSING_API_URL=https://po-cutting.5-223-78-194.sslip.io
ALLOWED_UPLOAD_ORIGINS=https://m88-po-cutting.netlify.app
